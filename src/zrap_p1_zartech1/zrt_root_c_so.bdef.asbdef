projection;
strict ( 2 );

define behavior for ZRT_ROOT_C_SO //alias <alias_name>
use etag
{
  use create;
  use update;
  use delete; // if we comment this then delete functionlity will be removed

  use association _Item { create; }
}

define behavior for ZRT_C_SOIT //alias <alias_name>
{

  use update;
  use delete; // if we comment this then delete functionlity will be removed

  use association _Header;
}